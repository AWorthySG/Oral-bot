# --- Copy this file to .env.local (for local dev) and set the values ---
# In production, set these in your Vercel project settings (Settings > Environment Variables).

# Anthropic API key for the AI examiner & feedback. Get one at https://console.anthropic.com
# If left blank, the site still works: timers, video, recording and self-review run,
# but the AI follow-up questions and AI feedback report show a "not configured" notice.
ANTHROPIC_API_KEY=

# Which Claude model to use. Sonnet is higher quality; Haiku is ~10x cheaper.
# Options: claude-sonnet-4-6 (default) or claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

# Passcode students type to enter the site. Pick anything and share it with your class.
CLASS_PASSCODE=oral2026
